{
    "manifest_version": 3,
    "name": "Browser Control MCP Bridge",
    "version": "0.1.0",
    "description": "WebSocket bridge for Browser Control MCP server",
    "permissions": ["tabs", "activeTab", "cookies", "scripting"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
